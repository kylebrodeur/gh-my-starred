{
  "name": "pi-gh-my-starred",
        "version": "0.4.4",
  "description": "PI extension for browsing GitHub starred repositories and star lists",
  "author": "kylebrodeur",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kylebrodeur/gh-my-starred.git"
  },
  "bugs": {
    "url": "https://github.com/kylebrodeur/gh-my-starred/issues"
  },
  "homepage": "https://github.com/kylebrodeur/gh-my-starred#readme",
  "keywords": [
    "pi-package",
    "pi-extension",
    "github",
    "starred-repositories",
    "github-cli"
  ],
  "main": ".pi/extensions/gh-my-starred.ts",
  "engines": {
    "node": ">=18.0.0"
  },
  "pi": {
    "extensions": [
      ".pi/extensions/gh-my-starred.ts",
      "node_modules/pi-librarian/extensions"
    ]
  },
  "scripts": {
    "test": "bash test/run.sh && node test/lib.test.js && node test/edge-cases.test.js",
    "prepare": "husky"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.78.1",
    "@types/node": "^25.6.0",
    "husky": "^9.1.7",
    "typebox": "^1.1.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "dependencies": {
    "pi-librarian": "^1.3.7",
    "sqlite3": "^6.0.1"
  },
  "bundledDependencies": ["pi-librarian"],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
    "files": [
    "dist",
    "src",
    ".pi",
    "README.md"
  ],
  "type": "module"
}
