#!/usr/bin/env bash
set -e

# Fetch starred repos and pipe to fzf
# Pressing 'enter' will open the repo in your browser
# Pressing 'ctrl-c' will just exit
selected=$(gh api --paginate user/starred --jq '.[].full_name' | \
  fzf --preview 'gh repo view {}' \
      --header 'Enter: Open in Browser | Ctrl-C: Exit')

if [ -n "$selected" ]; then
  gh repo view "$selected" --web
fi
